# Database Configuration
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/js_community

# Example for local development:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/js_community_dev

# Example for production (with SSL):
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Authentication Configuration
# Better-auth base URL (defaults to http://localhost:3000 in development)
BETTER_AUTH_URL=http://localhost:3000
# Alternative: NEXTAUTH_URL=http://localhost:3000
# Public application URL used for server-side fetches and email links in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better-auth secret for signing cookies and tokens
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# File uploads (required for avatars and inline uploads on Vercel)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Transactional email (required for password reset in production)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=JS Community <no-reply@example.com>

# Inngest (background job processing)
# Get keys from: https://app.inngest.com/
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Alpha-safe defaults
# Realtime is disabled by default on Vercel until a shared pub/sub backend is added
NEXT_PUBLIC_ENABLE_REALTIME=false

# OAuth Providers (optional)
# Google OAuth
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
